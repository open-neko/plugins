{
  "name": "@open-neko/plugin-parallel-search",
  "version": "0.2.0",
  "description": "Web search action for OpenNeko via Parallel.ai's search API. Runs in a microsandbox VM with network egress limited to api.parallel.ai.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-neko/plugins.git",
    "directory": "packages/parallel-search"
  },
  "type": "module",
  "files": ["dist", "README.md"],
  "openneko": {
    "runner": "./dist/run.js",
    "kinds": ["web_search", "web_fetch"],
    "requires_network": ["search.parallel.ai"]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@open-neko/plugin-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
