{
  "name": "@open-neko/plugin-slack",
  "version": "0.2.1",
  "description": "Slack for OpenNeko: a bidirectional channel (Block Kit briefings, findings and inline Approve/Reject; messages and button taps come back as agent intents) plus actions to post messages, send DMs, react, and look up users/channels. Runs in a sandbox VM with network egress limited to slack.com.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-neko/plugins.git",
    "directory": "packages/slack"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "skill"
  ],
  "openneko": {
    "runner": "./dist/run.js",
    "skill": "./skill",
    "permissions": {
      "network": [
        "slack.com"
      ],
      "env": [
        {
          "key": "SLACK_BOT_TOKEN",
          "required": true,
          "secret": true,
          "description": "xoxb-... bot token from your Slack app. Needs scopes: chat:write, im:write (for DMs), reactions:write, users:read, users:read.email (for email lookup), channels:read, groups:read (for channel lookup)."
        },
        {
          "key": "SLACK_SIGNING_SECRET",
          "required": false,
          "secret": true,
          "description": "Slack app signing secret - verifies inbound webhook requests (X-Slack-Signature over v0:<ts>:<body>). Required only when the channel surface receives webhooks; pure outbound/action use can omit it."
        }
      ]
    },
    "capabilities": {
      "action": {
        "kinds": [
          {
            "kind": "send_slack_message",
            "description": "Post a message to a Slack channel.",
            "default_mode": "auto",
            "example": {
              "channel": "#growth",
              "text": "Heads up \u2014 Q3 revenue just landed."
            }
          },
          {
            "kind": "send_slack_dm",
            "description": "Send a direct message to a Slack user. `user` may be a name, email, or Slack id.",
            "default_mode": "auto",
            "example": {
              "user": "amit",
              "text": "Stock for SKU-325 dipped below its reorder point."
            }
          },
          {
            "kind": "react_slack_message",
            "description": "Add an emoji reaction to a Slack message.",
            "default_mode": "auto",
            "example": {
              "channel": "C0123ABCD",
              "timestamp": "1700000000.000100",
              "name": "eyes"
            }
          },
          {
            "kind": "lookup_slack_entity",
            "description": "Look up a Slack user or channel by name or ID.",
            "default_mode": "auto",
            "example": {
              "type": "user",
              "query": "amit"
            }
          }
        ]
      },
      "channel": {
        "providerLabel": "Slack",
        "directions": [
          "outbound",
          "inbound"
        ],
        "ingress": "webhook",
        "profile": {
          "modalities": [
            "text",
            "visual"
          ],
          "richMedia": {
            "markdown": true,
            "cards": true,
            "charts": false,
            "images": true,
            "interactiveControls": true
          },
          "interaction": {
            "turnTaking": "async",
            "canApproveInline": true,
            "quickReplies": true
          },
          "constraints": {
            "latencyClass": "interactive",
            "attentionModel": "push"
          },
          "fidelity": "summary"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@open-neko/plugin-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
